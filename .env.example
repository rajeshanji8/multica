# Copy to .env and adjust as needed: `cp .env.example .env`
# docker compose reads these automatically.

# Host port the todo app is published on (http://localhost:<FRONTEND_PORT>).
FRONTEND_PORT=8080

# Allowed CORS origin for the backend. Only relevant if you expose the API
# directly to browsers instead of going through the frontend proxy.
CORS_ORIGIN=http://localhost:8080
